{{!
    @template block_timezoneclock/clock

    This template renders clock widget

    Example context (json):
    {
        "timezone": "Asia/Kolkata",
        "tz": "Asia/Kolkata",
        "blockautoupdate": false,
        "weekday": "Sun",
        "month": "Dec",
        "day": "18",
        "year": "2022",
        "hour": "12",
        "minute": "49",
        "second": "00",
        "dayPeriod": "PM",
        "indicators": [
            0,
            1,
            2,
            3,
            4
        ],
        "attributes": [
            {
                "name": "data-action",
                "value": "replacecomputertimezone"
            }
        ]
    }
}}
<div class="position-relative clockwrap" data-region="clock" data-timezone="{{tz}}"{{#blockautoupdate}} data-autoupdate="false"{{/blockautoupdate}}{{#attributes}} {{name}}="{{value}}" {{/attributes}}>
    <small class="position-absolute badge tztitle">{{timezone}}</small>
    {{#isanalog}}
        <div class="clock analogclock">
            <div class="clock__inner">
                <span data-fraction="g" class="hand clock__hour" data-unit="{{hour}}" style="--unit: {{hour}}">
                    <span class="sr-only">{{hour}}</span>
                </span>
                <span data-fraction="i" class="hand clock__minute" data-unit="{{minute}}" style="--unit: {{minute}}">
                    <span class="sr-only">{{minute}}</span>
                </span>
                <span data-fraction="s" class="hand clock__second" data-unit="{{second}}" style="--unit: {{second}}">
                    <span class="sr-only">{{second}}</span>
                </span>
                <span class="center hand clock__axis"></span>
                {{#indicators}}
                    <span class="clock__indicator" style="--nth-child: {{{.}}}"></span>
                {{/indicators}}
            </div>
            <span data-fraction="A" class="clock__dayPeriod unitdisplay" data-unit="{{dayPeriod}}">
                <span class="sr-only">{{dayPeriod}}</span>
            </span>
        </div>
        <p class="dateline badge mx-auto">
            {{#fractions}}
                {{^hide}}
                <span class="unitdisplay" data-fraction="{{{fraction}}}" data-unit="{{{value}}}">
                    <span class="sr-only">{{{value}}}</span>
                </span>
                {{/hide}}
            {{/fractions}}
        </p>
    {{/isanalog}}
    {{^isanalog}}
        <p class="clock digitalclock">
            {{#fractions}}
            <span class="unitdisplay" data-fraction="{{{fraction}}}" data-unit="{{{value}}}">
                <span class="sr-only">{{{value}}}</span>
            </span>
            {{/fractions}}
        </p>
    {{/isanalog}}
</div>
